DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mtgproject

# Session signing (set a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string
# Set to 1 when serving over HTTPS so the session cookie is secure-only
# SESSION_SECURE=1

# After a one-time DB migration from single-tenant data, sign in with this account
# LEGACY_ACCOUNT_EMAIL=legacy@mtg-archive.local
# LEGACY_ACCOUNT_PASSWORD=changeme
