DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mtgproject

# Session signing (set a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-string
# Set to 1 when serving over HTTPS so the session cookie is secure-only
# SESSION_SECURE=1

# When using local TLS (certs/), plain http:// on PORT is not served. Optional redirect:
# defaults to PORT+1 (e.g. 3002). Set to 0 to disable.
# HTTP_REDIRECT_PORT=3002

# Optional: extra cleartext HTTP port while TLS is on (camera/mic still need https:// server.url).
# CAPACITOR_HTTP_PORT=3100

# After a one-time DB migration from single-tenant data, sign in with this account
# LEGACY_ACCOUNT_EMAIL=legacy@mtg-archive.local
# LEGACY_ACCOUNT_PASSWORD=changeme

# CORS — whitelist the public origin in production (leave unset to allow localhost only)
# ALLOWED_ORIGIN=https://yourdomain.com

# Password reset emails (SMTP)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_yourapikey
# EMAIL_FROM=noreply@yourdomain.com
# APP_URL=https://yourdomain.com

# Automated release notes: same secret must be set on the server and used by scripts/changelog-add.js
# (Authorization: Bearer <secret> on POST /api/internal/changelog-ingest)
# CHANGELOG_INGEST_SECRET=generate-a-long-random-string
# Optional override for changelog:add (defaults to http://127.0.0.1:PORT).
# If the dev server runs HTTPS (mkcert), use https://127.0.0.1:3001 — the CLI trusts localhost TLS.
# MTG_API_URL=https://127.0.0.1:3001
