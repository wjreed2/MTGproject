{
  "name": "mtg-archive",
  "version": "1.0.0",
  "description": "MTG collection manager",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cat js/db-client.js js/auth.js js/state.js js/api.js js/ui.js js/ownership.js js/collection.js js/sets.js js/decks.js js/browse.js js/wishlist.js js/import.js js/analytics.js js/voice.js js/games.js js/scanner.js | npx esbuild --minify > dist/bundle.js",
    "build:watch": "npm run build && nodemon --watch js --ext js --exec 'npm run build'",
    "cap:sim": "node scripts/update-cap-ip.js --sim && npx cap sync",
    "cap:device": "node scripts/update-cap-ip.js && npx cap sync",
    "cap:sync": "npx cap sync",
    "setup:https": "bash scripts/setup-https.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "mysql2": "^3.6.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "nodemon": "^3.0.1"
  }
}
